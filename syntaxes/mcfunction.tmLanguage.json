{
  "name": "MCFunction",
  "scopeName": "source.mcfunction",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#commandLine"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.mcfunction",
          "match": "#.*$"
        }
      ]
    },
    "commandLine": {
      "patterns": [
        {
          "name": "keyword.control.command.mcfunction",
          "match": "^\\s*\\/?[a-z_][a-z0-9_]*"
        },
        {
          "name": "variable.parameter.selector.mcfunction",
          "match": "@[a-z]+(?:\\[[^\\]]*\\])?"
        },
        {
          "name": "constant.numeric.mcfunction",
          "match": "(?<![\\w.])[+-]?\\d+(?:\\.\\d+)?(?![\\w.])"
        },
        {
          "name": "constant.other.coordinate.mcfunction",
          "match": "[~^][+-]?\\d*(?:\\.\\d+)?"
        },
        {
          "name": "string.quoted.double.mcfunction",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mcfunction",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "keyword.operator.mcfunction",
          "match": "\\+\\=|\\-\\=|\\*\\=|\\/\\=|\\%\\=|><|<=|>=|=|<|>"
        },
        {
          "name": "support.type.parameter.mcfunction",
          "match": "(?<=\\s)[a-z_][a-z0-9_:.-]*(?=\\s|$)"
        }
      ]
    }
  }
}
